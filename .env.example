# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,auth-service,company-service,seeker-service,chat-service,ai-service,nginx

# Database - Auth Service
AUTH_DB_ENGINE=django.db.backends.mysql
AUTH_DB_NAME=auth_db
AUTH_DB_USER=root
AUTH_DB_PASSWORD=root123
AUTH_DB_HOST=mysql
AUTH_DB_PORT=3306

# Database - Company Service
COMPANY_DB_ENGINE=django.db.backends.mysql
COMPANY_DB_NAME=company_db
COMPANY_DB_USER=root
COMPANY_DB_PASSWORD=root123
COMPANY_DB_HOST=mysql
COMPANY_DB_PORT=3306

# Database - Seeker Service
SEEKER_DB_ENGINE=django.db.backends.mysql
SEEKER_DB_NAME=seeker_db
SEEKER_DB_USER=root
SEEKER_DB_PASSWORD=root123
SEEKER_DB_HOST=mysql
SEEKER_DB_PORT=3306

# Database - Chat Service
CHAT_DB_ENGINE=django.db.backends.mysql
CHAT_DB_NAME=chat_db
CHAT_DB_USER=root
CHAT_DB_PASSWORD=root123
CHAT_DB_HOST=mysql
CHAT_DB_PORT=3306

# Database - AI Service
AI_DB_ENGINE=django.db.backends.mysql
AI_DB_NAME=ai_db
AI_DB_USER=root
AI_DB_PASSWORD=root123
AI_DB_HOST=mysql
AI_DB_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@jobigo.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
CORS_ALLOW_CREDENTIALS=True

# AI Settings
OPENAI_API_KEY=sk-your-openai-key
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://auth-service:8001
COMPANY_SERVICE_URL=http://company-service:8002
SEEKER_SERVICE_URL=http://seeker-service:8003
CHAT_SERVICE_URL=http://chat-service:8004
AI_SERVICE_URL=http://ai-service:8005

# Environment
ENVIRONMENT=development
