# Top-level environment example for JobiGo

# MySQL root password used by all DB containers (change in production)
MYSQL_ROOT_PASSWORD=rootpassword

# Auth service DB
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

# Company service DB
COMPANY_DB_NAME=company_db
COMPANY_DB_USER=company_user
COMPANY_DB_PASSWORD=company_password

# Seeker service DB
SEEKER_DB_NAME=seeker_db
SEEKER_DB_USER=seeker_user
SEEKER_DB_PASSWORD=seeker_password

# Chat service DB
CHAT_DB_NAME=chat_db
CHAT_DB_USER=chat_user
CHAT_DB_PASSWORD=chat_password

# AI service DB
AI_DB_NAME=ai_db
AI_DB_USER=ai_user
AI_DB_PASSWORD=ai_password

# Redis
REDIS_URL=redis://redis:6379/0

# JWT / Auth
AUTH_JWT_PUBLIC_KEY=
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
