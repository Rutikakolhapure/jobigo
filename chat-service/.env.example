# Example env for chat-service

# Django
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Database (MySQL)
DB_NAME=chat_db
DB_USER=chat_user
DB_PASSWORD=chat_password
DB_HOST=chat_db
DB_PORT=3306

# Redis (Channels)
REDIS_URL=redis://redis:6379/0

# JWT (issued by auth-service)
# If using symmetric signing (HS256) set this to the shared secret.
# If using asymmetric (RS256) set AUTH_JWT_PUBLIC_KEY to public key and leave AUTH_JWT_SECRET blank.
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_PUBLIC_KEY=

# Other
SENTRY_DSN=
