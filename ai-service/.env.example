# Example env for ai-service

DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

DB_NAME=ai_db
DB_USER=ai_user
DB_PASSWORD=ai_password
DB_HOST=ai_db
DB_PORT=3306

# External services
COMPANY_SERVICE_URL=http://company-service:8002/api/company/
AUTH_SERVICE_URL=http://auth-service:8000/api/auth/

# OpenAI (or any compatible provider)
OPENAI_API_KEY=
OPENAI_MODEL=text-embedding-3-small
OPENAI_COMPLETION_MODEL=gpt-4o-mini

# Other
SENTRY_DSN=
